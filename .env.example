# ─── Telegram Bot ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=           # From @BotFather
BOT_USERNAME=RaizoPvPBot
ADMIN_TELEGRAM_ID=            # Your Telegram user ID (get from @userinfobot)

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/raizogames
# Railway PostgreSQL: set this in the Railway Variables panel (auto-linked)

# ─── OxaPay (USDT payments) ───────────────────────────────────────────────────
OXAPAY_MERCHANT_KEY=          # From oxapay.com → Merchant → API Keys
OXAPAY_WEBHOOK_SECRET=        # Optional but recommended — set in OxaPay dashboard

# ─── Webhook / App URL ────────────────────────────────────────────────────────
# Your Railway app public URL — used for OxaPay payment callbacks
# Railway provides this automatically as a domain like: https://yourapp.up.railway.app
WEBHOOK_URL=https://your-app.up.railway.app

# ─── Session ──────────────────────────────────────────────────────────────────
SESSION_SECRET=               # Long random string, e.g. openssl rand -hex 32

# ─── Node ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
